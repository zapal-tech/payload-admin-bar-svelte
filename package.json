{
  "name": "@zapal/payload-admin-bar-svelte",
  "version": "1.0.1",
  "private": false,
  "description": "Payload CMS Admin Bar for Svelte",
  "keywords": [
    "payload",
    "cms",
    "admin",
    "bar",
    "svelte",
    "zapal",
    "zapal-tech"
  ],
  "bugs": {
    "url": "https://github.com/zapal-tech/payload-admin-bar-svelte/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/zapal-tech/payload-admin-bar-svelte.git"
  },
  "license": "MIT",
  "author": {
    "name": "Zapal",
    "email": "hello@zapal.tech",
    "url": "https://zapal.tech"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js"
    }
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "scripts": {
    "build": "vite build && pnpm run prepack",
    "check": "pnpm run sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "pnpm run check --watch",
    "check-updates": "pnpx taze major -r -l",
    "clean": "rimraf dist *.tsbuildinfo zapal-payload-admin-bar-svelte-*.tgz",
    "dev": "vite dev",
    "format": "prettier --write .",
    "lint": "pnpm run format && eslint . --ignore-pattern='dist/' --ignore-pattern='.svelte-kit/'",
    "prepack": "pnpm run sync && svelte-package && publint && sed -i 's/utm_source=github/utm_source=npm/g' README.md",
    "postpack": "git checkout -- README.md",
    "prepare": "husky && pnpm run sync || echo ''",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "preview": "vite preview",
    "sync": "svelte-kit sync",
    "test": "pnpm run test:unit --run",
    "test:unit": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.57.1",
    "@sveltejs/package": "2.5.7",
    "@sveltejs/vite-plugin-svelte": "7.0.0",
    "@types/node": "^24",
    "@zapal/dx": "^1.4.0",
    "eslint": "9.39.1",
    "globals": "^17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "payload": "3.83.0",
    "prettier": "3.8.3",
    "prettier-plugin-packagejson": "3.0.2",
    "prettier-plugin-svelte": "3.5.1",
    "publint": "0.3.18",
    "rimraf": "6.1.3",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
    "typescript": "5.9.3",
    "vite": "8.0.9",
    "vitest": "4.1.5",
    "vitest-browser-svelte": "2.1.1"
  },
  "peerDependencies": {
    "payload": "^3.26.0",
    "svelte": "^5.0.0"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
